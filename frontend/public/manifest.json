{
  "name": "Sporta komandas vadības sistēma",
  "short_name": "TeamFlow",
  "description": "Sporta komandas grafika, apmeklējuma un saziņas pārvaldība",
  "start_url": "/?pwa=true",
  "scope": "/",
  "display": "standalone",
  "display_override": ["standalone", "minimal-ui", "browser"],
  "orientation": "portrait-primary",
  "theme_color": "#667eea",
  "background_color": "#ffffff",
  "categories": ["sports", "productivity"],
  "prefer_related_applications": false,
  "screenshots": [
    {
      "src": "/screenshot-small.png",
      "sizes": "540x720",
      "type": "image/png",
      "mode": "any",
      "form_factor": "narrow"
    },
    {
      "src": "/screenshot-large.png",
      "sizes": "1080x1440",
      "type": "image/png",
      "mode": "any",
      "form_factor": "wide"
    }
  ],
  "icons": [
    {
      "src": "/launchericon-48x48.png",
      "sizes": "48x48",
      "type": "image/png"
    },
    {
      "src": "/launchericon-72x72.png",
      "sizes": "72x72",
      "type": "image/png"
    },
    {
      "src": "/launchericon-96x96.png",
      "sizes": "96x96",
      "type": "image/png"
    },
    {
      "src": "/launchericon-144x144.png",
      "sizes": "144x144",
      "type": "image/png"
    },
    {
      "src": "/launchericon-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/launchericon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    }
  ],
  "shortcuts": [
    {
      "name": "Izveidot komandu",
      "short_name": "Jauna komanda",
      "description": "Ātri izveidot jaunu komandu",
      "url": "/create-team",
      "icons": [{ "src": "/launchericon-96x96.png", "sizes": "96x96", "type": "image/png" }]
    },
    {
      "name": "Pievienoties komandai",
      "short_name": "Pievienoties",
      "description": "Pievienoties esošai komandai",
      "url": "/join-team",
      "icons": [{ "src": "/launchericon-96x96.png", "sizes": "96x96", "type": "image/png" }]
    }
  ],
  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "files": [
        {
          "name": "file",
          "accept": ["text/*", "application/*"]
        }
      ]
    }
  }
